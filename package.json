{
  "name": "grund-ui",
  "version": "0.0.1",
  "description": "A headless, accessible Web Component library built with Lit",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js",
    "./accordion": "./dist/components/accordion/accordion.js",
    "./checkbox": "./dist/components/checkbox/checkbox.js",
    "./tabs": "./dist/components/tabs/tabs.js",
    "./toggle": "./dist/components/toggle/toggle.js",
    "./toggle-group": "./dist/components/toggle-group/toggle-group.js"
  },
  "customElements": "custom-elements.json",
  "files": [
    "dist",
    "custom-elements.json"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && tsc --emitDeclarationOnly --declarationMap",
    "test": "vitest",
    "test:run": "vitest run --project=components",
    "test:storybook": "vitest run --config=vitest.storybook.config.ts",
    "test:visual": "vitest run --project=visual",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "lint": "eslint src/ stories/",
    "format": "prettier --write \"src/**/*.ts\"",
    "analyze": "cem analyze --litelement"
  },
  "keywords": [
    "web-components",
    "lit",
    "headless",
    "accessible",
    "a11y"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ewice/grund-ui"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@lit/context": "^1.1.6",
    "lit": "^3.3.2"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^5.0.2",
    "@custom-elements-manifest/analyzer": "^0.11.0",
    "@eslint/js": "^10.0.1",
    "@open-wc/testing": "^4.0.0",
    "@storybook/addon-a11y": "^10.3.1",
    "@storybook/addon-docs": "^10.3.1",
    "@storybook/addon-vitest": "^10.3.1",
    "@storybook/web-components-vite": "^10.3.1",
    "@vitest/browser": "^4.1.0",
    "@vitest/browser-playwright": "^4.1.0",
    "@vitest/coverage-v8": "^4.1.0",
    "eslint": "^10.0.3",
    "eslint-plugin-lit": "^2.2.1",
    "eslint-plugin-storybook": "^10.3.1",
    "eslint-plugin-wc": "^3.1.0",
    "playwright": "^1.58.2",
    "prettier": "^3.8.1",
    "storybook": "^10.3.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
